{
    "version": 2,
    "builds": [
        {
            "src": "api/contact.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "cleanUrls": true,
    "routes": [
        {
            "src": "/api/contact",
            "dest": "/api/contact.js"
        },
        {
            "src": "/projects",
            "dest": "/public/projects/index.html"
        },
        {
            "src": "/projects/(.*)",
            "dest": "/public/projects/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}